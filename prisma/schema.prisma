generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  passwordHash  String
  emailVerified DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  // Security: Invalidate all sessions on password change
  tokenVersion Int @default(1)

  sessions Session[]

  @@map("users")
}

model Session {
  id         String   @id // Detailed session ID (random high-entropy string), NOT auto-increment
  userId     String
  expiresAt  DateTime
  userAgent  String?
  ipAddress  String?
  lastActive DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("sessions")
}

enum TokenType {
  EMAIL_VERIFICATION
  PASSWORD_RESET
}

model VerificationToken {
  identifier String // Email or UserID
  tokenHash  String // Hashed version of the token sent to user
  type       TokenType
  expires    DateTime

  @@unique([identifier, type])
  @@map("verification_tokens")
}
